// ⚠️ 已废弃：由 docs/系统心智模型.md 取代，不再更新。本文件保留作历史归档。
// Writer 系统 C4 模型
// 对齐 docs/架构分层图.md 的四层结构: L1 Context / L2 Container / L3 Component
// 目录名严格对齐代码, 不用别名; LikeC4 用 FQN(点号)表达层级, 不用子 model 块

specification {
  // ---- 角色 ----
  element actor {
    style {
      shape person
      color green
    }
  }

  // ---- 外部系统 ----
  element external-system {
    notation "External System"
    style {
      opacity 20%
      color muted
    }
  }

  // ---- 系统级 ----
  element system {
    notation "Software System"
    style {
      opacity 20%
    }
  }

  // ---- Container 层(L2): 可部署/运行的进程或前端包 ----
  element container-web {
    notation "Frontend (Web)"
    style {
      shape browser
    }
  }

  element container-service {
    notation "Service (Backend)"
    style {
      opacity 20%
    }
  }

  // ---- Component 层(L3): 层/模块 ----
  element layer {
    style {
      shape rectangle
      opacity 20%
    }
  }

  element component {
    style {
      shape rectangle
      opacity 20%
    }
  }

  // ---- 共享包 ----
  element shared-package {
    notation "Shared Package"
    style {
      shape rectangle
      opacity 30%
    }
  }

  // ---- 数据存储 ----
  element database {
    notation "Database"
    style {
      shape storage
      opacity 30%
    }
  }
}

model {
  // ==================== L1 · System Context ====================
  author = actor '作者 / 编剧' {
    description '使用 Writer 进行创作, 提需求 / 看剧本'
    -> writer.frontend '提需求 / 看剧本'
  }

  llm = external-system '大模型 (DeepSeek 等)' {
    description '被两端共同调用'
  }

  writer = system 'Writer' {
    description 'AI 辅助写作 + 进化系统'

    // ---- L2 容器 ----
    frontend = container-web 'Frontend 前端网页' {
      technology 'Next.js'
      description '用户唯一入口. 只碰 executor, 不直接碰 evolution'
      -> executor 'HTTP 请求'
    }

    executor = container-service 'executor 执行端' {
      technology 'FastAPI / Python'
      description '写作执行服务. 接前端 HTTP + 接 evolution 的 /internal'
      this -> llm '调用'
      this -> writer.evolution '被 evolution 调用 /internal: ab/run(生成) + ab/status(轮询) + snapshot/refreshed(发版通知)'
      this -> writer.db '读写'

      // ============= executor 内部分层(L2 Container 内部, 对齐分层铁律 routers->domains->platform->harness) =============
      routers = layer 'app/routers/' {
        description 'HTTP 路由层. 接前端 + 接 evolution 的 /internal'
        this -> domains '转给业务域'
      }
      domains = layer 'app/domains/' {
        description '业务域层 (writing 写作 / image 图像)'
        this -> platform '调用'
      }
      platform = layer 'app/platform/' {
        description '公共底座层 (agent 装配 / trace / 状态 / 鉴权)'
        this -> harness '加载'

        // ============= platform 内部组件(L3, 对齐分层图 L3 platform 视图) =============
        agentPlatform = component 'agent/' {
          description 'Agent 装配 + loader + runtime'
          this -> prompt '装配时读'
        }
        trace = component 'trace/' {
          description '执行轨迹记录. 完成后通知 evolution'
          this -> writer.evolution '通知 trace 完成'
        }
        state = component 'state/' {
          description '工作区 / 风格 / 产物存储'
        }
        streaming = component 'streaming/' {
          description 'SSE 流式输出'
        }
        prompt = component 'prompt/' {
          description 'prompt 加载 + label 切换'
        }
        auth = component 'auth/' {
          description '鉴权'
        }
        memoryBackend = component 'app/platform/memory/ (记忆系统固定基础设施)' {
          description '记忆系统固定基础设施(不可进化). MemoryBackend 四原语: retrieve(四阶段检索) + add_episode(章节入图) + ingest_storybuilding(蓝图入图) + health_check. 封装 Graphiti+FalkorDB+LLM(json_schema降级)+embedder(智谱embedding-3). 存储=FalkorDB(writer-falkordb docker服务, Redis协议时序知识图谱). 进程单例懒加载, 连不上自动关闭记忆功能降级全量注入'
        }
      }
      harness = layer 'evolution/harnesses/current/' {
        description 'Agent 包 (流水线装配 + prompt + skill). 被 platform 加载, 不反向依赖. 记忆可进化要素: middleware/memory_recall_middleware.py(查询构造+证据包组装) + tools/narrative_schema(实体/边类型) + tools/storyline_parser + tools/story_calendar(虚构历法)'
      }

      // ============= domains/writing 内部组件(L3, 对齐分层图 L3 writing 视图) =============
      meta = component 'agent.py (MetaAgentService)' {
        description '写作流水线总指挥'
        this -> subagents '委托'
        this -> styleSvc '风格注入'
        this -> events '领域事件分发'
      }
      subagents = component 'expert_agent/services/' {
        description '四岗位子代理 (访谈 / 故事建筑 / 分场 / 正文)'
        this -> styleSvc '读'
      }
      styleSvc = component 'styling/' {
        description '风格注入'
      }
      events = component 'events.py' {
        description '领域事件分发'
      }
    }

    evolution = container-service 'evolution 进化端' {
      technology 'FastAPI / Python'
      description '三功能 + 双 Agent: ①单次测试 ②评估 Agent ③进化 Agent. 用户主导, 人工串联闭环'
      this -> writer.executor '③拉取 trace / A/B 生成 / ⑦推送快照发布通知'
      this -> llm '调用 (评估 Agent + 进化 Agent)'
      this -> writer.db '读写'

      // ============= evolution 内部分层(L2 Container 内部, 对齐三功能解耦) =============
      // 三功能各自独立(决策 T1-T11/S1-S14):
      //   ① 单次测试: tests/ 选数据集+版本 → 调 executor 跑 → 产 trace
      //   ② 评估 Agent: eval_agent/ 独立顶层 Agent, 对一条 trace 做诊断
      //   ③ 进化 Agent: evolve/ 吃评估报告 → 方案→执行 → 产待审改动 → 人工发版
      evolveApi = layer 'app/evolve/api.py (进化 API)' {
        description '功能③触发: POST /evolve/start (强前置: trace 必须已评估) + 发版/丢弃'
        this -> singleAgent '触发进化驱动器'
      }
      evalAgentApi = layer 'app/eval_agent/api.py (评估 API)' {
        description '功能②触发: POST /eval-agent/start (选 trace) + 查询 + SSE'
        this -> evalAgent '触发评估 Agent'
      }
      testsApi = layer 'app/tests/ (单次测试)' {
        description '功能①: 选数据集+Agent版本 → 调 executor /internal/ab/run → 产 trace. 已就绪'
        this -> writer.executor.routers 'HTTP /internal/ab/run 跑生成'
      }

      // —— 双 Agent(对等的独立顶层 Agent, 互不依赖, 各自只依赖 core+common) ——
      evalAgent = layer 'app/eval_agent/ (评估 Agent)' {
        description '功能②: 独立顶层 DeepAgent. 按要素分层: prompt + tools/(trace·surface·content·report) + middleware/no_fs + skills/(空壳). 读 trace 多层 + 流程硬指标 + 内容评分(scoring+rubrics内含) + LLM 诊断. 只诊断不提方案(T3). 按版本对齐要素(V1-V7)'
        this -> evoCore '读写 (evaluation_sessions 表)'
        this -> harnessConfig '读 harness 设计意图 (read_surface, 按版本)'
      }
      singleAgent = layer 'app/evolve/ (进化 Agent)' {
        description '功能③: 按要素分层. driver/(agent+prompt+middleware/phase_guard) 委托 subagents/(plan·execute 各 prompt/tools/build 三件套) + skills/(空壳). 吃评估报告产改动, 不自证比分(T1人工发版). P4: 读 trace memory_quality 摘要(flow.py) + 查 reflection(含记忆失败模式) 注入进化上下文'
        this -> harnessConfig '执行子代理改 harness 源码'
        this -> evoCore '读写 (evolve_sessions 表 + eval_ref 关联评估)'
      }

      // —— 公共设施(跨 Agent 共用, 不属任一业务 Agent) ——
      common = layer 'app/common/ (公共设施)' {
        description 'events(SSE总线) + flow_metrics(流程指标) + evalset(评估集) + model_factory(LLM模型工厂). eval_agent 与 evolve 平等依赖'
      }

      // —— 反思库(P4 记忆失败模式归纳) ——
      reflection = layer 'app/reflection/ (反思库)' {
        description '归纳评估 badcase + 记忆失败模式(recall_miss 召回空 / retrieval_fail 检索异常) → reflection_library. extract_after_scoring 在评估后调, 从 trace run_meta 事件读 memory_quality 埋点. 被 evolve agent 启动时查询注入(Reflexion 式)'
        this -> evoCore '读写 (reflection_library 表)'
      }

      // —— 底座(被三功能共用) ——
      harnessConfig = layer 'app/harness_config/ (装配层)' {
        description 'HarnessConfig schema+序列化+校验(config) + apply_edits算子(edits) + bootstrap(v1生成). git_ops已归core'
        this -> harnessSrc '改写/读取 harness 源码'
      }
      versioning = layer 'app/versioning/ (版本谱系+发版)' {
        description 'snapshot_repo(版本快照 config_json+source_commit) + snapshot_publisher(发版通知) + snapshot_api'
      }
      evoCore = layer 'app/core/ (底座)' {
        description 'DB + LLM + settings + models(trace schema) + git_ops(commit/show_file 按版本读源码)'
      }
      harnessSrc = layer 'harnesses/current/ (Agent 包源码)' {
        description '被进化 Agent 改写的对象. git 管理, 发版时 commit+push 到 bare repo'
      }
    }

    db = database 'Database' {
      technology 'SQLite'
      description '两端各自的元数据/trace 存储(分库)'
    }
  }

  // ---- 外部关系: 前端 + evolution 进 executor 都打在 routers ----
  writer.frontend -> writer.executor.routers 'HTTP'
  evolution -> writer.executor.routers 'HTTP /internal'

  // ---- 记忆系统关系(跨层, FQN 表达) ----
  // 写入路径: writing 域事件钩子 → 入图(经 ingestion.py 异步, 不阻断 SSE)
  writer.executor.events -> writer.executor.platform.memoryBackend 'storybuilding/章节完成入图(asyncio.to_thread)'
  // 读取路径: harness 的 memory_recall middleware 调 retrieve(经 RuntimeContext 注入, 非 harness 反向 import platform, 不违分层铁律)
  writer.executor.harness -> writer.executor.platform.memoryBackend 'memory_recall 调 retrieve 四阶段检索(经 ctx 注入)'
  // 进化闭环: 评估后归纳 + 进化时查询注入
  writer.evolution.evalAgent -> writer.evolution.reflection '评估后归纳记忆失败模式(extract_from_memory_quality)'
  writer.evolution.singleAgent -> writer.evolution.reflection '查记忆失败模式注入进化上下文'

  // ---- contracts 共享包(独立, 只被依赖不依赖任何一端) ----
  contracts = shared-package 'contracts/' {
    description '两端的数据合同. 铁律: 只被依赖, 不 import executor 也不 import evolution. 记忆字段: RuntimeContext.memory_backend + memory_recall_middleware_cls(双注入, 复用T2模式); TraceMemoryQuality(检索质量埋点, P4进化闭环用)'
  }
  writer.executor -> contracts 'import'
  writer.evolution -> contracts 'import'
}

// ==================== Views ====================
views {
  // L1 · 系统总览(给所有人)
  view index {
    title 'Writer 系统总览 (L1 Context)'
    include *
  }

  // L1 · Writer Context
  view writerContext of writer {
    title 'Writer — System Context'
    include author, llm
  }

  // L2 · executor 容器视图(给开发: 看动哪层)
  view executorContainer of writer.executor {
    title 'executor — Container 视图'
    include *
  }

  // L2 · evolution 容器视图
  view evolutionContainer of writer.evolution {
    title 'evolution — Container 视图'
    include *
  }

  // L3 · platform 内部组件(改底座时看)
  view executorPlatform of writer.executor.platform {
    title 'executor · platform/ — Component 视图'
    include *
  }

  // L3 · writing 域内部(改写作流水线时看)
  view executorWriting of writer.executor.domains {
    title 'executor · domains/ — Component 视图'
    include *
  }

  // 记忆系统总览
  // 记忆系统总览 — 固定基础设施(executor) + 可进化要素(harness) + 进化闭环(evolution)
  // 跨容器视图: 一个地方看全记忆系统的三层结构(对齐 Phase 1-4 设计)
  view memoryView {
    title '记忆系统总览 — 固定基础设施 + 可进化要素 + 进化闭环'
    description '两层设计: 固定基础设施(executor/platform/memory) + 可进化要素(harness). 三流: 写入/读取/进化闭环. 主色=固定, 次色=可进化'
    include
      writer.executor.platform.memoryBackend,
      writer.executor.harness,
      writer.executor.events,
      writer.evolution.reflection,
      writer.evolution.singleAgent,
      writer.evolution.evalAgent,
      writer.evolution.evoCore
    style writer.executor.platform.memoryBackend {
      color primary
    }
    style writer.executor.harness {
      color secondary
    }
  }

  // L4 · 跨端进化闭环(动态视图, 对齐三功能解耦)
  // 三功能各自独立, 人工串联: 测试产 trace → 评估诊断 → 进化产版本 → 人工发版 → 回测试验证
  dynamic view evolutionLoop {
    title 'L4 · 三功能进化闭环'
    description '
      ①单次测试 → ②评估 Agent → ③进化 Agent → 人工发版 → 回①验证.
      三功能各自独立不串入对方流程, 用户手动串联(T1人工拍板发版).
    '

    // —— 功能① 单次测试: 用户选数据集+版本, 调执行端跑生成 ——
    author -> writer.evolution.testsApi '选数据集+Agent版本' {
      notes '功能①: 用户在进化端发起单次测试'
    }
    writer.evolution.testsApi -> writer.executor.routers 'HTTP /internal/ab/run' {
      notes '调执行端跑一次生成, 不自动进入进化'
    }
    writer.executor.routers -> writer.evolution.testsApi '返回 trace_id'
    writer.evolution.testsApi -> writer.evolution.evoCore '存 manual_tests (version+trace_id)'

    // —— 功能② 评估 Agent: 对 trace 做诊断 ——
    author -> writer.evolution.evalAgentApi '选一条 trace 评估' {
      notes '功能②: 用户选 trace, 评估 Agent 诊断流程+内容, 只诊断不提方案'
    }
    writer.evolution.evalAgentApi -> writer.evolution.evalAgent '启动评估 Agent'
    writer.evolution.evalAgent -> writer.evolution.evoCore '写 evaluation_sessions (scores+findings+report)' {
      notes '评估报告落 DB, 作为进化的强前置输入'
    }

    // —— 功能③ 进化 Agent: 吃评估报告产改动 ——
    author -> writer.evolution.evolveApi '选已评估 trace 进化' {
      notes '功能③: 强前置(S8) - trace 必须已有评估报告'
    }
    writer.evolution.evolveApi -> writer.evolution.evoCore '校验: 该 trace 有 done 评估?'
    writer.evolution.evolveApi -> writer.evolution.singleAgent '启动进化驱动器(方案→执行)'
    writer.evolution.singleAgent -> writer.evolution.harnessConfig '执行子代理改 harness 源码'
    writer.evolution.singleAgent -> writer.evolution.evoCore '存 evolve_sessions (status=pending_review)' {
      notes '产待审改动, working 区锁定'
    }

    // —— 人工发版: 用户 review 后固化新版本 ——
    author -> writer.evolution.evolveApi '发版 / 丢弃' {
      notes 'T1 人工拍板. 发版=git commit+config快照+通知执行端; 丢弃=git reset'
    }
    writer.evolution.evolveApi -> writer.evolution.evoCore 'publish_config (config_json+source_commit)' {
      notes '存 harness_snapshots 新 production, 旧 production 降 retired'
    }
    writer.evolution.evolveApi -> writer.executor.routers 'HTTP 通知快照发布' {
      notes 'POST /internal/snapshot/refreshed. 执行端下次重载新 harness'
    }

    // —— 回到①验证: 新版本好不好要走测试+评估才知道(T8人工串联) ——
    author -> writer.evolution.testsApi '拿新版本再测试' {
      notes '闭环: 发版后用户手动拿新版本跑测试→评估, 对比新旧评估报告'
    }

    // 样式: 把 Writer 系统内的元素压暗, 突出跨端交互
    include
      writer with {
        color gray
        opacity 10%
      }
    style * {
      color secondary
    }
    style author {
      color green
    }
  }

  // L4 · 记忆系统数据流(动态视图, 三条流: 写入/读取/进化闭环)
  // 对齐 Phase 1-4 实现: 入图钩子(events.py) → 四阶段检索(retrieve) → 记忆质量埋点→反思→进化
  dynamic view memoryFlow {
    title 'L4 · 记忆系统数据流 (写入 / 读取 / 进化闭环)'
    description '①写入(Causal Publish Flow): storybuilding/章节完成 → events 钩子 → ingestion → MemoryBackend → FalkorDB. ②读取: writing 子代理 → memory_recall middleware(harness可进化) → retrieve 四阶段检索 → EvidencePacket 注入 prompt. ③进化闭环(P4): middleware 写 memory_quality 埋点 → trace → reflection 归纳失败模式 → evolve agent 查注入 → 改 harness 可进化要素.'

    // —— ①写入流: Causal Publish Flow ——
    writer.executor.events -> writer.executor.platform.memoryBackend 'storybuilding/章节完成触发入图' {
      notes 'events.py 的 _on_storybuilding_done/_on_writing_chapter_done 钩子, asyncio.to_thread 异步不阻断 SSE'
    }
    writer.executor.platform.memoryBackend -> writer.executor.platform.memoryBackend 'ingestion → backend.add_episode/ingest_storybuilding' {
      notes 'MemoryBackend 调 Graphiti add_episode(章节) 或 结构化建节点(蓝图). 失败写 .memory_unhealthy flag 阻断后续 memory_recall'
    }

    // —— ②读取流: 四阶段检索注入 ——
    writer.executor.harness -> writer.executor.platform.memoryBackend 'memory_recall middleware 调 retrieve' {
      notes '四阶段: Causal Restriction(因果截止) → Hybrid(BM25+Vector) → One-Hop(图扩展) → Bounded Assembly(有界证据包). 经 RuntimeContext 注入, 非 harness 反向 import'
    }
    writer.executor.platform.memoryBackend -> writer.executor.harness '返回 EvidencePacket 注入子代理 prompt' {
      notes '有界证据包(≤budget_chars), 按角色→关系→地点→事件叙事优先级排版'
    }

    // —— ③进化闭环(P4): 记忆质量 → 反思 → 进化 ——
    writer.executor.harness -> writer.evolution.evoCore 'memory_recall 写 memory_quality 埋点(run_meta 事件)' {
      notes 'TraceMemoryQuality: chapter_num/query/evidence_nodes_count/retrieval_ok 等. 随 trace 落库'
    }
    writer.evolution.evalAgent -> writer.evolution.reflection '评估后归纳记忆失败模式' {
      notes 'extract_from_memory_quality: retrieval_ok=False→retrieval_fail; 召回0节点0边→recall_miss'
    }
    writer.evolution.singleAgent -> writer.evolution.reflection '查记忆失败模式注入进化上下文' {
      notes 'evolve agent 启动时按 dimension 查 reflection_library(含记忆类别), flow.py 读 memory_quality 摘要'
    }
    writer.evolution.singleAgent -> writer.executor.harness '产改动: 改记忆可进化要素(middleware/tools)' {
      notes '进化产出的改动落到 harness repo 的 memory_recall_middleware / narrative_schema / storyline_parser 等'
    }

    // 样式: 固定基础设施主色, 可进化要素次色
    style writer.executor.platform.memoryBackend {
      color primary
    }
    style writer.executor.harness {
      color secondary
    }
  }
}
