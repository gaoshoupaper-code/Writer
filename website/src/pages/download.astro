---
/// 下载页（Editorial 重设计，与首页同一视觉语言）。
/// 安装包托管在 executor 服务器的 nginx /releases/ 静态目录。
/// 版本号硬编码（发版时改这里 + Content Collections），避免构建时 fetch 失败。
//
/// ⚠️ 安装包当前未购买微软代码签名证书（Authenticode），浏览器会提示"不常下载"、
/// Windows 会弹 SmartScreen。这是正常现象，已在下方给出操作指引。
/// Tauri 更新签名（minisign）已配，自动更新不受影响。

const VERSION = "0.1.1";
const MSI_URL = `https://siyen.site/releases/siyen-${VERSION}-windows.msi`;
const EXE_URL = `https://siyen.site/releases/siyen-${VERSION}-windows-setup.exe`;

// 下载项（图标用线条 SVG，不用 emoji）
const downloads = [
  {
    label: "安装包",
    ext: ".exe",
    size: "3.6 MB",
    url: EXE_URL,
    primary: true,
    note: "体积更小，安装更顺滑，推荐大多数用户。",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>`,
  },
  {
    label: "安装包",
    ext: ".msi",
    size: "5.3 MB",
    url: MSI_URL,
    primary: false,
    note: "适合企业批量部署，功能与 .exe 完全相同。",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>`,
  },
];

// 安全提示步骤
const steps = [
  {
    title: "浏览器下载提示",
    body: "下载时 Edge / Chrome 可能提示「通常不在下载中」或「文件不常见」。",
    items: [
      "Edge：点击「···」→「保留」，或「仍要下载」",
      "Chrome：点击「仍要下载」",
    ],
  },
  {
    title: "运行时 SmartScreen 拦截",
    body: "双击安装包后，Windows 可能弹出蓝色窗口「已保护你的电脑」。",
    items: [
      "点击「更多信息」",
      "然后点击「仍要运行」",
    ],
    hint: "随下载量积累，该警告会逐步消失。购买正式代码签名证书后可彻底消除。",
  },
];

/// 排版体系（token + body 基底）放 public/styles/base.css，两页 <link> 引入。
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-256.png" sizes="256x256" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16.png" sizes="16x16" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="下载思衍桌面端 — Windows 10 / 11，自动更新，离线缓存。" />
    <title>下载思衍 — Windows</title>
    {/* 共享基底：颜色 token + 排版 scale + body reset */}
    <link rel="stylesheet" href="/styles/base.css" />
    {/* 本地子集字体：cn-font-split 切成 68 个 unicode-range 分片，
        浏览器按页用字按需拉取（首屏 <100KB），取代外网 Google Fonts。 */}
    <link rel="stylesheet" href="/fonts/noto-serif-sc/regular/index.css" />
    <link rel="stylesheet" href="/fonts/noto-serif-sc/semibold/index.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="wrap topbar__inner">
        <a href="/" class="brand" aria-label="思衍 首页">
          <img class="brand__mark" src="/favicon-256.png" alt="" width="26" height="26" />
          <span class="brand__name">思衍</span>
        </a>
        <nav class="topbar__nav" aria-label="主导航">
          <a href="/">首页</a>
          <a href="/#features">特性</a>
          <a href="/download" class="topbar__cta is-active" aria-current="page">下载</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- ============ HERO：非对称，左标题右版本 ============ -->
      <section class="hero">
        <div class="wrap hero__grid">
          <div class="hero__lead">
            <p class="kicker"><span class="kicker__dot"></span>下载 · v{VERSION}</p>
            <h1 class="hero__title">
              在 Windows 上<br />
              <em>开始写作</em>。
            </h1>
            <p class="hero__sub">
              桌面端支持离线缓存、自动更新。两个安装包功能完全相同，选其一即可。
            </p>
          </div>
          <aside class="hero__rail">
            <dl class="facts">
              <div class="facts__row">
                <dt>平台</dt>
                <dd>Windows 10 / 11（64 位）</dd>
              </div>
              <div class="facts__row">
                <dt>版本</dt>
                <dd>v{VERSION}</dd>
              </div>
              <div class="facts__row">
                <dt>体积</dt>
                <dd>3.6 MB（.exe）</dd>
              </div>
              <div class="facts__row">
                <dt>依赖</dt>
                <dd>WebView2 运行时<span class="facts__hint">Win11 内置，安装时会自动引导</span></dd>
              </div>
            </dl>
          </aside>
        </div>
      </section>

      <!-- ============ 下载卡片 ============ -->
      <section class="downloads">
        <div class="wrap">
          <header class="section-head">
            <span class="section-num">02</span>
            <div class="section-head__text">
              <h2 class="section-title">选择安装包</h2>
              <p class="section-lead">推荐 .exe，体积更小，安装更顺滑。</p>
            </div>
          </header>

          <div class="dl-grid">
            {downloads.map((d) => (
              <a
                href={d.url}
                class:list={["dl-card", { "dl-card--primary": d.primary }]}
              >
                <span class="dl-card__icon" set:html={d.icon} aria-hidden="true"></span>
                <span class="dl-card__main">
                  <span class="dl-card__label">{d.label} <em>{d.ext}</em></span>
                  <span class="dl-card__note">{d.note}</span>
                </span>
                <span class="dl-card__meta">
                  <span class="dl-card__size">{d.size}</span>
                  <span class="dl-card__cta" aria-hidden="true">下载 →</span>
                </span>
              </a>
            ))}
          </div>

          <p class="post-note">
            安装过程会自动引导安装 WebView2 运行时（Windows 11 已内置）。联网后即可使用全部写作功能。
          </p>
        </div>
      </section>

      <!-- ============ 安全提示：编辑式步骤 ============ -->
      <section class="warning">
        <div class="wrap">
          <header class="section-head">
            <span class="section-num">03</span>
            <div class="section-head__text">
              <h2 class="section-title">关于<em>安全提示</em></h2>
              <p class="section-lead">
                思衍尚未购买微软代码签名证书，浏览器与 Windows 会拦截。<strong>软件本身安全</strong>，请按以下步骤操作。
              </p>
            </div>
          </header>

          <ol class="steps">
            {steps.map((s, i) => (
              <li class="step">
                <span class="step__num">{String(i + 1).padStart(2, "0")}</span>
                <div class="step__body">
                  <h3 class="step__title">{s.title}</h3>
                  <p class="step__desc">{s.body}</p>
                  <ul class="step__list">
                    {s.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                  {s.hint && <p class="step__hint">{s.hint}</p>}
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="wrap foot__inner">
        <span class="foot__copy">© 2026 思衍</span>
        <span class="foot__seal" aria-hidden="true">写</span>
        <nav class="foot__nav">
          <a href="/">首页</a>
          <a href="/#features">特性</a>
        </nav>
      </div>
    </footer>

    <style>
      /* ---------- 全局基底 & token：见 src/styles/base.css ---------- */

      /* 本页独有 token：安全提示色板 + 更窄容器（下载页内容少于首页）。
         颜色 / 字体 / 排版 scale 都在 base.css，这里只补差异。 */
      :root {
        --warn-bg: #fbf3e0;
        --warn-bd: #e6d4a8;
        --warn-ink: #6b4f12;
        --maxw: 1080px;
      }

      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 32px; }

      /* ---------- 顶部栏（同首页）---------- */
      .topbar { border-bottom: 1px solid var(--rule); }
      .topbar__inner {
        display: flex; align-items: center; justify-content: space-between;
        height: 68px;
      }
      .brand { display: inline-flex; align-items: center; gap: 9px; text-decoration: none; color: var(--ink); }
      .brand__mark { width: 26px; height: 26px; }
      .brand__name { font-family: var(--font-serif); font-weight: var(--fw-semibold); font-size: var(--fs-brand); letter-spacing: var(--tracking-cn); }
      .topbar__nav { display: flex; align-items: center; gap: 28px; }
      .topbar__nav a {
        text-decoration: none; color: var(--ink-2);
        font-family: var(--font-sans); font-size: var(--fs-body);
        transition: color .2s;
      }
      .topbar__nav a:hover { color: var(--ink); }
      .topbar__cta { color: var(--ink) !important; font-weight: var(--fw-semibold); }
      /* 当前页：朱砂短下划线标识 */
      .topbar__nav a.is-active {
        position: relative; color: var(--ink); font-weight: var(--fw-semibold);
      }
      .topbar__nav a.is-active::after {
        content: ""; position: absolute; left: 0; right: 0; bottom: -6px;
        height: 2px; background: var(--vermilion);
      }

      /* ---------- HERO ---------- */
      .hero { padding: 72px 0 80px; border-bottom: 1px solid var(--rule); }
      .hero__grid {
        display: grid;
        grid-template-columns: 1.35fr 1fr;
        gap: 64px;
        align-items: start;
      }
      .kicker {
        display: inline-flex; align-items: center; gap: 9px;
        font-family: var(--font-sans); font-size: var(--fs-kicker);
        color: var(--ink-3); letter-spacing: var(--tracking-cn-body);
        margin-bottom: 26px;
      }
      .kicker__dot { width: 6px; height: 6px; background: var(--vermilion); border-radius: 50%; }
      .hero__title {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-display);
        line-height: var(--lh-tight); letter-spacing: var(--tracking-cn-tight); color: var(--ink);
      }
      .hero__title em { font-style: italic; color: var(--vermilion); }
      .hero__sub {
        margin-top: 28px; max-width: 30em;
        font-size: var(--fs-body-lg); color: var(--ink-2); line-height: var(--lh-body);
      }

      /* HERO 右栏：事实表 */
      .hero__rail { padding: 4px 0 4px 28px; border-left: 1px solid var(--rule); }
      .facts { display: flex; flex-direction: column; }
      .facts__row {
        display: grid; grid-template-columns: 5em 1fr;
        gap: 16px; padding: 14px 0;
        border-bottom: 1px solid var(--rule);
      }
      .facts__row:last-child { border-bottom: none; }
      .facts dt {
        font-family: var(--font-sans); font-size: var(--fs-meta);
        color: var(--ink-3); letter-spacing: var(--tracking-label);
        text-transform: uppercase; padding-top: 3px;
      }
      .facts dd { font-family: var(--font-serif); font-size: var(--fs-body); line-height: var(--lh-body); letter-spacing: var(--tracking-cn-body); color: var(--ink); font-variant-numeric: tabular-nums; }
      .facts__hint { display: block; font-family: var(--font-sans); font-size: var(--fs-meta); color: var(--ink-3); margin-top: 2px; }

      /* ---------- 下载卡片 ---------- */
      .downloads { padding: 88px 0 72px; border-bottom: 1px solid var(--rule); }
      .section-head {
        display: grid; grid-template-columns: auto 1fr; column-gap: 24px;
        align-items: start; margin-bottom: 48px; max-width: 720px;
      }
      .section-num {
        font-family: var(--font-serif); font-size: var(--fs-body);
        font-weight: var(--fw-semibold);
        color: var(--vermilion); padding-top: 10px;
      }
      .section-title {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-h3); line-height: var(--lh-tight);
        letter-spacing: var(--tracking-cn); color: var(--ink);
      }
      .section-title em { font-style: italic; color: var(--vermilion); }
      .section-lead { margin-top: 14px; font-size: var(--fs-body); line-height: var(--lh-body); letter-spacing: var(--tracking-cn-body); color: var(--ink-2); max-width: 34em; }
      .section-lead strong { color: var(--ink); }

      .dl-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      .dl-card {
        position: relative;
        display: grid; grid-template-columns: auto 1fr auto;
        align-items: center; gap: 20px;
        padding: 28px 28px;
        text-decoration: none; color: var(--ink);
        background: var(--paper);
        border: 1px solid var(--rule);
        transition: border-color .25s ease, background .25s ease;
      }
      .dl-card:hover { border-color: var(--ink); background: var(--paper-2); }
      .dl-card--primary { border-color: var(--ink); }
      .dl-card--primary:hover { border-color: var(--vermilion); }
      .dl-card__icon {
        display: inline-flex; width: 34px; height: 34px; color: var(--ink);
      }
      .dl-card--primary .dl-card__icon { color: var(--vermilion); }
      .dl-card__icon :global(svg) { width: 100%; height: 100%; }
      .dl-card__main { display: flex; flex-direction: column; min-width: 0; }
      .dl-card__label {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-body-lg); line-height: var(--lh-tight);
        letter-spacing: var(--tracking-cn); color: var(--ink);
      }
      .dl-card__label em { font-style: normal; color: var(--ink-3); font-family: var(--font-sans); font-size: var(--fs-small); font-weight: var(--fw-regular); margin-left: 4px; }
      .dl-card__note { font-family: var(--font-sans); font-size: var(--fs-small); line-height: var(--lh-body); color: var(--ink-3); margin-top: 3px; }
      .dl-card__meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
      .dl-card__size {
        font-family: var(--font-mono); font-size: var(--fs-small); color: var(--ink-2); font-variant-numeric: tabular-nums;
        background: var(--paper-2); padding: 3px 8px; border-radius: 3px;
      }
      .dl-card__cta {
        font-family: var(--font-sans); font-size: var(--fs-small);
        font-weight: var(--fw-semibold); color: var(--ink);
        transition: transform .25s ease;
      }
      .dl-card:hover .dl-card__cta { transform: translateX(3px); }

      .post-note {
        margin-top: 24px; font-family: var(--font-serif);
        font-size: var(--fs-body); line-height: var(--lh-body);
        letter-spacing: var(--tracking-cn-body); color: var(--ink-3);
        max-width: 50em;
      }

      /* ---------- 安全提示 ---------- */
      .warning { padding: 88px 0 96px; }
      .steps { list-style: none; counter-reset: none; }
      .step {
        display: grid; grid-template-columns: auto 1fr; gap: 28px;
        padding: 28px 0;
        border-top: 1px solid var(--rule);
      }
      .step:first-child { border-top: none; padding-top: 0; }
      .step:last-child { padding-bottom: 0; }
      .step__num {
        font-family: var(--font-serif); font-size: var(--fs-h4);
        font-weight: var(--fw-semibold); color: var(--vermilion);
        line-height: var(--lh-tight);
      }
      .step__body { max-width: 44em; }
      .step__title {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-h5); line-height: var(--lh-tight);
        letter-spacing: var(--tracking-cn); color: var(--ink); margin-bottom: 8px;
      }
      .step__desc { font-family: var(--font-serif); font-size: var(--fs-body); line-height: var(--lh-body); letter-spacing: var(--tracking-cn-body); color: var(--ink-2); margin-bottom: 12px; }
      .step__list { list-style: none; padding: 0; }
      .step__list li {
        position: relative; padding-left: 18px;
        font-family: var(--font-serif); font-size: var(--fs-body);
        line-height: var(--lh-body); letter-spacing: var(--tracking-cn-body);
        color: var(--ink-2); margin-top: 8px;
      }
      .step__list li::before {
        content: ""; position: absolute; left: 0; top: 0.7em;
        width: 8px; height: 1px; background: var(--vermilion);
      }
      .step__hint {
        margin-top: 14px; padding: 12px 16px;
        background: var(--warn-bg); border-left: 3px solid var(--vermilion);
        font-family: var(--font-sans); font-size: var(--fs-small);
        line-height: var(--lh-body); color: var(--warn-ink);
      }

      /* ---------- FOOTER（同首页）---------- */
      .foot { border-top: 1px solid var(--rule); }
      .foot__inner {
        display: flex; align-items: center; justify-content: space-between;
        height: 76px; gap: 24px;
      }
      .foot__copy { font-family: var(--font-sans); font-size: var(--fs-small); color: var(--ink-3); }
      .foot__seal {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-meta);
        color: var(--paper); background: var(--vermilion);
        width: 26px; height: 26px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 3px; letter-spacing: 0;
      }
      .foot__nav { display: flex; gap: 24px; }
      .foot__nav a { text-decoration: none; font-family: var(--font-sans); font-size: var(--fs-small); color: var(--ink-2); transition: color .2s; }
      .foot__nav a:hover { color: var(--ink); }

      /* ---------- 响应式 ---------- */
      @media (max-width: 900px) {
        .wrap { padding: 0 22px; }
        .hero { padding: 48px 0 56px; }
        .hero__grid { grid-template-columns: 1fr; gap: 40px; }
        .hero__rail { border-left: none; border-top: 1px solid var(--rule); padding: 32px 0 0; }
        .downloads { padding: 64px 0; }
        .dl-grid { grid-template-columns: 1fr; }
        .warning { padding: 64px 0 72px; }
        .step { grid-template-columns: 1fr; gap: 12px; }
        .foot__inner { height: 64px; }
      }
      @media (max-width: 480px) {
        .topbar__nav { gap: 16px; }
        .section-head { grid-template-columns: 1fr; }
        .dl-card { grid-template-columns: auto 1fr; }
        .dl-card__meta { grid-column: 1 / -1; flex-direction: row; align-items: center; justify-content: space-between; padding-top: 4px; border-top: 1px dashed var(--rule); }
      }

      @media (prefers-reduced-motion: reduce) {
        .dl-card, .dl-card__cta { transition: none; }
        :global(html) { scroll-behavior: auto; }
      }
    </style>
  </body>
</html>
