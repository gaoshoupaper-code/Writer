---
import { getCollection } from "astro:content";

/// 官网首页（Editorial 重设计）。
/// 设计方向：墨纸气质 / 衬线展示字 + 无衬线正文 / 单一朱砂点缀 / 非对称布局。
/// 功能介绍内容来自 Content Collections（src/content/features/*.md），
/// 改内容 = 改 md 文件 + 重新构建，无需 CMS 后台。

const features = (await getCollection("features")).sort(
  (a, b) => a.data.order - b.data.order
);

// 写作流水线四阶段（与 ai-writing.md / README 一致），提升到 hero 右栏作非对称重点。
const pipeline = [
  { num: "01", name: "访谈", desc: "结构化问答，收集创作需求" },
  { num: "02", name: "大纲", desc: "世界观 · 主线 · 人物关系" },
  { num: "03", name: "章节", desc: "按大纲逐章生成正文" },
  { num: "04", name: "审查", desc: "风格统一与质量把关" },
];

// 特性图标：手绘线条 SVG，不用 emoji。
const icons: Record<string, string> = {
  pen: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
  offline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19a4.5 4.5 0 0 0 0-9 6 6 0 0 0-9.5-2"/><path d="M5.5 9.5A5 5 0 0 0 6 19h2"/><path d="m2 2 20 20"/></svg>`,
  update: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-2.6-6.4"/><path d="M21 4v5h-5"/></svg>`,
};
const icon = (name?: string) => (name && icons[name] ? icons[name] : icons.pen);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-256.png" sizes="256x256" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16.png" sizes="16x16" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="思衍 — 多 Agent 协作的 AI 写作桌面端，从大纲到章节逐层生成。" />
    <title>思衍 — 多 Agent 协作的 AI 写作引擎</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;900&display=swap"
    />
  </head>
  <body>
    <header class="topbar">
      <div class="wrap topbar__inner">
        <a href="/" class="brand" aria-label="思衍 首页">
          <img class="brand__mark" src="/favicon-256.png" alt="" width="26" height="26" />
          <span class="brand__name">思衍</span>
        </a>
        <nav class="topbar__nav" aria-label="主导航">
          <a href="/" class="is-active" aria-current="page">首页</a>
          <a href="#features">特性</a>
          <a href="/download" class="topbar__cta">下载 <span aria-hidden="true">→</span></a>
        </nav>
      </div>
    </header>

    <main>
      <!-- ============ HERO：非对称两栏 ============ -->
      <section class="hero">
        <div class="wrap hero__grid">
          <div class="hero__lead">
            <p class="kicker"><span class="kicker__dot"></span>AI 写作引擎 · 桌面端</p>
            <h1 class="hero__title">
              从一句话大纲，<br />
              写到<em>一整本书</em>。
            </h1>
            <p class="hero__sub">
              多 Agent 协作的写作流水线：访谈、大纲、章节、审查，逐层推进，产出可追溯、可回溯。桌面端离线缓存，自动更新。
            </p>
            <div class="hero__cta">
              <a class="btn" href="/download">
                <span>下载桌面端</span><span class="btn__arrow" aria-hidden="true">→</span>
              </a>
              <span class="hero__meta">v0.1.0 · Windows 10 / 11</span>
            </div>
          </div>

          <aside class="hero__rail" aria-label="写作流水线">
            <p class="rail__label">写作流水线</p>
            <ol class="pipeline">
              {pipeline.map((stage) => (
                <li class="pipeline__item">
                  <span class="pipeline__node" aria-hidden="true"></span>
                  <span class="pipeline__num">{stage.num}</span>
                  <span class="pipeline__body">
                    <span class="pipeline__name">{stage.name}</span>
                    <span class="pipeline__desc">{stage.desc}</span>
                  </span>
                </li>
              ))}
            </ol>
          </aside>
        </div>
      </section>

      <!-- ============ FEATURES：非对称 bento ============ -->
      <section id="features" class="features">
        <div class="wrap">
          <header class="section-head">
            <span class="section-num">02</span>
            <div class="section-head__text">
              <h2 class="section-title">为长篇创作<br />而设计</h2>
              <p class="section-lead">
                不是"提示词 → 文本"的一次性工具，而是分层的协作系统。
              </p>
            </div>
          </header>

          <div class="bento">
            {features.map((feature, i) => (
              <article class:list={["card", { "card--lead": i === 0 }]}>
                <span class="card__icon" set:html={icon(feature.data.icon)} aria-hidden="true"></span>
                <h3 class="card__title">{feature.data.title}</h3>
                <p class="card__desc">{feature.data.description}</p>
                <div class="card__body" set:html={feature.body}></div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ============ CLOSING：克制的收尾 CTA ============ -->
      <section class="closing">
        <div class="wrap closing__inner">
          <p class="closing__line">准备好写下你的第一本书了吗？</p>
          <a class="btn btn--solid" href="/download">
            <span>下载思衍</span><span class="btn__arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="wrap foot__inner">
        <span class="foot__copy">© 2026 思衍</span>
        <span class="foot__seal" aria-hidden="true">写</span>
        <nav class="foot__nav">
          <a href="#features">特性</a>
          <a href="/download">下载</a>
        </nav>
      </div>
    </footer>

    <style>
      /* ---------- 全局基底 ---------- */
      :global(*) { margin: 0; padding: 0; box-sizing: border-box; }
      :global(html) { scroll-behavior: smooth; }
      :global(body) {
        font-family: system-ui, -apple-system, "PingFang SC", "Microsoft YaHei", "Segoe UI", sans-serif;
        color: var(--ink);
        background: var(--paper);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      :global(::selection) { background: var(--vermilion); color: var(--paper); }

      :root {
        --paper:   #f6f3ec;
        --paper-2: #efeae0;
        --ink:     #1a1612;
        --ink-2:   #4a4239;
        --ink-3:   #8b8174;
        --rule:    #d8d0c1;
        --vermilion: #9a2f2f;
        --serif: "Noto Serif SC", "Songti SC", "STSong", "Source Han Serif SC", "SimSun", serif;
        --maxw: 1120px;
      }

      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 32px; }

      /* ---------- 顶部栏 ---------- */
      .topbar { border-bottom: 1px solid var(--rule); }
      .topbar__inner {
        display: flex; align-items: center; justify-content: space-between;
        height: 68px;
      }
      .brand { display: inline-flex; align-items: center; gap: 9px; text-decoration: none; color: var(--ink); }
      .brand__mark { width: 26px; height: 26px; }
      .brand__name { font-family: var(--serif); font-weight: 900; font-size: 21px; letter-spacing: 0.01em; }
      .topbar__nav { display: flex; align-items: center; gap: 28px; }
      .topbar__nav a {
        text-decoration: none; color: var(--ink-2); font-size: 15px;
        transition: color .2s;
      }
      .topbar__nav a:hover { color: var(--ink); }
      .topbar__cta { color: var(--ink) !important; font-weight: 600; }
      /* 当前页：朱砂短下划线标识（不抢 CTA 视觉） */
      .topbar__nav a.is-active {
        position: relative; color: var(--ink); font-weight: 600;
      }
      .topbar__nav a.is-active::after {
        content: ""; position: absolute; left: 0; right: 0; bottom: -6px;
        height: 2px; background: var(--vermilion);
      }
      .topbar__cta.is-active::after { display: none; }

      /* ---------- HERO ---------- */
      .hero { padding: 88px 0 104px; border-bottom: 1px solid var(--rule); }
      .hero__grid {
        display: grid;
        grid-template-columns: 1.35fr 1fr;
        gap: 64px;
        align-items: start;
      }
      .kicker {
        display: inline-flex; align-items: center; gap: 9px;
        font-size: 13px; color: var(--ink-3); letter-spacing: 0.04em;
        margin-bottom: 26px;
      }
      .kicker__dot { width: 6px; height: 6px; background: var(--vermilion); border-radius: 50%; }
      .hero__title {
        font-family: var(--serif); font-weight: 900;
        font-size: clamp(40px, 6.4vw, 78px);
        line-height: 1.06; letter-spacing: -0.01em; color: var(--ink);
      }
      .hero__title em { font-style: italic; color: var(--vermilion); }
      .hero__sub {
        margin-top: 28px; max-width: 30em;
        font-size: 17px; color: var(--ink-2); line-height: 1.7;
      }
      .hero__cta { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; margin-top: 40px; }
      .hero__meta { font-size: 13px; color: var(--ink-3); font-variant-numeric: tabular-nums; }

      /* 按钮：墨水填充 hover */
      .btn {
        position: relative; overflow: hidden; isolation: isolate;
        display: inline-flex; align-items: center; gap: 10px;
        padding: 14px 26px;
        font-size: 15px; font-weight: 600; text-decoration: none;
        color: var(--ink); background: transparent;
        border: 1px solid var(--ink);
        transition: color .25s ease;
      }
      .btn::before {
        content: ""; position: absolute; inset: 0; z-index: -1;
        background: var(--ink); transform: translateY(101%);
        transition: transform .3s cubic-bezier(.4,0,.2,1);
      }
      .btn:hover { color: var(--paper); }
      .btn:hover::before { transform: translateY(0); }
      .btn:hover .btn__arrow { transform: translateX(3px); }
      .btn__arrow { transition: transform .25s ease; }
      .btn--solid { color: var(--paper); }
      .btn--solid::before { transform: translateY(0); }
      .btn--solid:hover { color: var(--paper); }

      /* HERO 右栏：流水线 spine */
      .hero__rail {
        padding: 4px 0 4px 28px;
        border-left: 1px solid var(--rule);
      }
      .rail__label {
        font-size: 12px; color: var(--ink-3); letter-spacing: 0.12em;
        text-transform: uppercase; margin-bottom: 22px;
      }
      .pipeline { list-style: none; position: relative; }
      .pipeline__item {
        position: relative; display: grid;
        grid-template-columns: auto 1fr; column-gap: 14px;
        padding: 14px 0 14px 22px;
      }
      /* 竖线 + 节点 */
      .pipeline::before {
        content: ""; position: absolute; left: 4px; top: 8px; bottom: 8px;
        width: 1px; background: var(--rule);
      }
      .pipeline__node {
        position: absolute; left: 0; top: 22px;
        width: 9px; height: 9px; border-radius: 50%;
        background: var(--paper); border: 1.5px solid var(--ink-3);
      }
      .pipeline__item:first-child .pipeline__node { border-color: var(--vermilion); background: var(--vermilion); }
      .pipeline__num {
        font-size: 12px; color: var(--ink-3); font-variant-numeric: tabular-nums;
        align-self: start; padding-top: 2px; letter-spacing: 0.06em;
      }
      .pipeline__body { display: flex; flex-direction: column; }
      .pipeline__name { font-family: var(--serif); font-weight: 600; font-size: 17px; color: var(--ink); }
      .pipeline__desc { font-size: 13px; color: var(--ink-3); margin-top: 2px; }

      /* ---------- FEATURES bento ---------- */
      .features { padding: 104px 0 96px; }
      .section-head {
        display: grid; grid-template-columns: auto 1fr; column-gap: 24px;
        align-items: start; margin-bottom: 56px; max-width: 720px;
      }
      .section-num {
        font-family: var(--serif); font-size: 15px; font-weight: 600;
        color: var(--vermilion); padding-top: 10px;
      }
      .section-title {
        font-family: var(--serif); font-weight: 900;
        font-size: clamp(30px, 4.2vw, 48px); line-height: 1.08; color: var(--ink);
      }
      .section-lead { margin-top: 16px; font-size: 16px; color: var(--ink-2); max-width: 34em; }

      .bento {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        grid-template-rows: auto auto;
        gap: 1px;
        background: var(--rule);
        border: 1px solid var(--rule);
      }
      .card {
        background: var(--paper);
        padding: 40px 38px;
        transition: background .25s ease;
      }
      .card:hover { background: var(--paper-2); }
      .card--lead { grid-row: span 2; padding: 48px 46px; }
      .card__icon {
        display: inline-flex; width: 38px; height: 38px; margin-bottom: 22px;
        color: var(--ink);
      }
      .card__icon :global(svg) { width: 100%; height: 100%; }
      .card--lead .card__icon { width: 46px; height: 46px; }
      .card__title {
        font-family: var(--serif); font-weight: 600;
        font-size: clamp(20px, 2vw, 25px); color: var(--ink);
      }
      .card--lead .card__title { font-size: clamp(24px, 2.6vw, 32px); }
      .card__desc { margin-top: 8px; font-size: 15px; color: var(--ink-3); }
      .card__body { margin-top: 20px; }
      /* markdown h1 与 frontmatter title 重复，隐藏前者 */
      .card__body :global(h1:first-child) { display: none; }
      .card__body :global(p) { font-size: 14.5px; color: var(--ink-2); line-height: 1.7; }
      .card__body :global(p) + :global(ul) { margin-top: 12px; }
      .card__body :global(ul) { list-style: none; padding: 0; }
      .card__body :global(li) {
        position: relative; padding-left: 18px;
        font-size: 14.5px; color: var(--ink-2); margin-top: 9px; line-height: 1.6;
      }
      .card__body :global(li)::before {
        content: ""; position: absolute; left: 0; top: 0.7em;
        width: 8px; height: 1px; background: var(--vermilion);
      }

      /* ---------- CLOSING ---------- */
      .closing { border-top: 1px solid var(--rule); padding: 88px 0; }
      .closing__inner {
        display: flex; align-items: center; justify-content: space-between;
        gap: 32px; flex-wrap: wrap;
      }
      .closing__line {
        font-family: var(--serif); font-weight: 600;
        font-size: clamp(22px, 2.6vw, 30px); color: var(--ink);
      }

      /* ---------- FOOTER ---------- */
      .foot { border-top: 1px solid var(--rule); }
      .foot__inner {
        display: flex; align-items: center; justify-content: space-between;
        height: 76px; gap: 24px;
      }
      .foot__copy { font-size: 13px; color: var(--ink-3); }
      .foot__seal {
        font-family: var(--serif); font-weight: 900; font-size: 13px;
        color: var(--paper); background: var(--vermilion);
        width: 26px; height: 26px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 3px; letter-spacing: 0;
      }
      .foot__nav { display: flex; gap: 24px; }
      .foot__nav a { text-decoration: none; color: var(--ink-2); font-size: 14px; transition: color .2s; }
      .foot__nav a:hover { color: var(--ink); }

      /* ---------- 响应式 ---------- */
      @media (max-width: 900px) {
        .wrap { padding: 0 22px; }
        .hero { padding: 56px 0 64px; }
        .hero__grid { grid-template-columns: 1fr; gap: 48px; }
        .hero__rail { border-left: none; border-top: 1px solid var(--rule); padding: 32px 0 0; }
        .features { padding: 72px 0; }
        .bento { grid-template-columns: 1fr; }
        .card--lead { grid-row: auto; padding: 36px 30px; }
        .card { padding: 32px 30px; }
        .closing { padding: 56px 0; }
        .closing__inner { justify-content: flex-start; }
        .foot__inner { height: 64px; }
      }
      @media (max-width: 480px) {
        .topbar__nav { gap: 16px; }
        .topbar__nav a { font-size: 14px; }
        .hero__title { font-size: 42px; }
        .hero__cta { gap: 14px; }
        .section-head { grid-template-columns: 1fr; }
      }

      @media (prefers-reduced-motion: reduce) {
        .btn::before, .btn__arrow, .card { transition: none; }
        :global(html) { scroll-behavior: auto; }
      }
    </style>
  </body>
</html>
