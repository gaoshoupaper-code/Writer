---
import { getCollection } from "astro:content";

/// 官网首页（Editorial 重设计）。
/// 设计方向：墨纸气质 / 衬线展示字 + 无衬线正文 / 单一朱砂点缀 / 非对称布局。
/// 功能介绍内容来自 Content Collections（src/content/features/*.md），
/// 改内容 = 改 md 文件 + 重新构建，无需 CMS 后台。

const features = (await getCollection("features")).sort(
  (a, b) => a.data.order - b.data.order
);

// 写作流水线四阶段（与 ai-writing.md 一致），提升到 hero 右栏作非对称重点。
// 描述用网文作者看得懂的大白话：动作 + 结果，不堆术语。
const pipeline = [
  { num: "01", name: "访谈", desc: "先问你几个问题，把故事想清楚" },
  { num: "02", name: "大纲", desc: "搭好世界观、主线、人物" },
  { num: "03", name: "章节", desc: "按大纲一章一章往下写" },
  { num: "04", name: "审查", desc: "逐章查风格，把 AI 味磨掉" },
];

// 特性图标：手绘线条 SVG，不用 emoji。
// pathLength="1" 让每个 path 用统一的 0→1 描边进度做 stroke-draw 动画。
const icons: Record<string, string> = {
  pen: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9" pathLength="1"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" pathLength="1"/></svg>`,
  offline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19a4.5 4.5 0 0 0 0-9 6 6 0 0 0-9.5-2" pathLength="1"/><path d="M5.5 9.5A5 5 0 0 0 6 19h2" pathLength="1"/><path d="m2 2 20 20" pathLength="1"/></svg>`,
  update: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-2.6-6.4" pathLength="1"/><path d="M21 4v5h-5" pathLength="1"/></svg>`,
};
const icon = (name?: string) => (name && icons[name] ? icons[name] : icons.pen);

/// 排版体系（token + body 基底）放 public/styles/base.css，两页 <link> 引入。
/// 改字号 / 字距 / 行高 → 改 base.css，无需碰页面。
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-256.png" sizes="256x256" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16.png" sizes="16x16" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="思衍 — 你把故事想法告诉它，它从大纲到章节一路写完整本书。设定不崩、文笔不飘。" />
    <title>思衍 — AI 长篇小说引擎</title>
    {/* 共享基底：颜色 token + 排版 scale + body reset */}
    <link rel="stylesheet" href="/styles/base.css" />
    {/* 本地子集字体：cn-font-split 切成 68 个 unicode-range 分片，
        浏览器按页用字按需拉取（首屏 <100KB），取代外网 Google Fonts。 */}
    <link rel="stylesheet" href="/fonts/noto-serif-sc/regular/index.css" />
    <link rel="stylesheet" href="/fonts/noto-serif-sc/semibold/index.css" />
    <script is:inline>
      // 在 paint 之前就先声明 .js 标记，避免 reveal 元素从「可见 → 不可见 → 可见」的闪烁
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <header class="topbar" data-topbar>
      <div class="wrap topbar__inner">
        <a href="/" class="brand" aria-label="思衍 首页">
          <img class="brand__mark" src="/favicon-256.png" alt="" width="26" height="26" />
          <span class="brand__name">思衍</span>
        </a>
        <nav class="topbar__nav" aria-label="主导航">
          <a href="/" class="is-active" aria-current="page">首页</a>
          <a href="#features">特性</a>
          <a href="/download" class="topbar__cta">下载 <span aria-hidden="true">→</span></a>
        </nav>
      </div>
    </header>

    <main>
      <!-- ============ HERO：非对称两栏 ============ -->
      <section class="hero">
        <div class="wrap hero__grid">
          <div class="hero__lead">
            <p class="kicker" data-reveal><span class="kicker__dot"></span>AI 长篇小说引擎 · 桌面端</p>
            <h1 class="hero__title" data-reveal aria-label="写出属于你的故事世界">
              写出属于你的<br />
              <em class="typer" aria-hidden="true" data-typer="故事世界">故事世界</em><span class="caret" aria-hidden="true"></span>
            </h1>
            <p class="hero__sub" data-reveal>
              你把故事想法告诉它，它从大纲到章节一路写完整本书。设定不崩、文笔不飘，中途想插手随时能改——不想插手，让它全自动跑完也行。
            </p>
            <div class="hero__cta" data-reveal>
              <a class="btn" href="/download" data-magnetic>
                <span>下载桌面端</span><span class="btn__arrow" aria-hidden="true">→</span>
              </a>
              <span class="hero__meta">v0.1.1 · Windows 10 / 11</span>
            </div>
          </div>

          <aside class="hero__rail" data-reveal aria-label="写作流水线">
            <p class="rail__label">写作流水线</p>
            <ol class="pipeline">
              {pipeline.map((stage, i) => (
                <li class="pipeline__item" style={`--idx:${i}`}>
                  <span class="pipeline__node" aria-hidden="true"></span>
                  <span class="pipeline__num">{stage.num}</span>
                  <span class="pipeline__body">
                    <span class="pipeline__name">{stage.name}</span>
                    <span class="pipeline__desc">{stage.desc}</span>
                  </span>
                </li>
              ))}
            </ol>
          </aside>
        </div>
      </section>

      <!-- ============ FEATURES：非对称 bento ============ -->
      <section id="features" class="features">
        <div class="wrap">
          <header class="section-head" data-reveal>
            <span class="section-num">02</span>
            <div class="section-head__text">
              <h2 class="section-title">为长篇创作<br />而设计</h2>
              <p class="section-lead">
                不是一问一答的一次性工具，是从想法到成书的全自动流水线。
              </p>
            </div>
          </header>

          <div class="bento">
            {features.map((feature, i) => (
              <article class:list={["card", { "card--lead": i === 0 }]} data-reveal>
                <span class="card__icon" set:html={icon(feature.data.icon)} aria-hidden="true"></span>
                <h3 class="card__title">{feature.data.title}</h3>
                <p class="card__desc">{feature.data.description}</p>
                <div class="card__body" set:html={feature.body}></div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ============ CLOSING：克制的收尾 CTA ============ -->
      <section class="closing">
        <div class="wrap closing__inner">
          <p class="closing__line" data-reveal>你脑子里那个故事，该写出来了。</p>
          <a class="btn btn--solid" href="/download" data-magnetic>
            <span>下载思衍</span><span class="btn__arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="wrap foot__inner">
        <span class="foot__copy">© 2026 思衍</span>
        <span class="foot__seal" aria-hidden="true">写</span>
        <nav class="foot__nav">
          <a href="#features">特性</a>
          <a href="/download">下载</a>
        </nav>
      </div>
    </footer>

    <script>
      // 动效总和尊重 prefers-reduced-motion：偏好减弱动效的用户直接跳过全部增强。
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      // 滚动渐显：IntersectionObserver 观察所有 [data-reveal]，
      // 交错延迟来自同一观察批次的索引，避免硬编码 nth-child 的维护成本。
      const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
      if (reduceMotion) {
        revealEls.forEach((el) => el.classList.add("is-revealed"));
      } else if ("IntersectionObserver" in window && revealEls.length) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            const incoming = entries.filter((e) => e.isIntersecting);
            incoming
              // 稳定顺序：保证 stagger 顺序不受回调先后影响
              .sort(
                (a, b) =>
                  Array.from(revealEls).indexOf(a.target) -
                  Array.from(revealEls).indexOf(b.target)
              )
              .forEach((entry, i) => {
                (entry.target as HTMLElement).style.setProperty(
                  "--reveal-i",
                  String(i)
                );
                entry.target.classList.add("is-revealed");
                obs.unobserve(entry.target);
              });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add("is-revealed"));
      }

      // 顶部栏：向下滚动时收起、置顶时展开；用 rAF 节流滚动事件
      const topbar = document.querySelector<HTMLElement>("[data-topbar]");
      if (topbar) {
        let ticking = false;
        let last = 0;
        const onScroll = () => {
          const y = window.scrollY;
          // 离开顶部 24px 才切换状态，避免微小抖动
          topbar.dataset.scrolled = y > 24 ? "true" : "false";
          topbar.dataset.hidden = y > last + 8 && y > 120 ? "true" : "false";
          last = y;
          ticking = false;
        };
        window.addEventListener(
          "scroll",
          () => {
            if (!ticking) {
              requestAnimationFrame(onScroll);
              ticking = true;
            }
          },
          { passive: true }
        );
      }

      // 按钮磁吸：指针靠近时朝指针方向轻微位移（仅精确指针设备）
      if (!reduceMotion && window.matchMedia("(pointer: fine)").matches) {
        document
          .querySelectorAll<HTMLElement>("[data-magnetic]")
          .forEach((btn) => {
            const strength = 0.22; // 位移系数，克制不浮夸
            const onMove = (e: MouseEvent) => {
              const r = btn.getBoundingClientRect();
              btn.style.setProperty("--mx", `${(e.clientX - r.left) * strength}px`);
              btn.style.setProperty("--my", `${(e.clientY - r.top) * strength}px`);
            };
            const reset = () => {
              btn.style.setProperty("--mx", "0px");
              btn.style.setProperty("--my", "0px");
            };
            btn.addEventListener("mousemove", onMove);
            btn.addEventListener("mouseleave", reset);
          });
      }

      // ---- 动效 1：Hero 标题打字机 ----
      // "写出属于你的" 静态显示，"故事世界" 逐字敲出，呼应写作主题。
      // 读屏拿 aria-label 的完整文本；视觉层 aria-hidden 由 JS 接管。
      const typer = document.querySelector<HTMLElement>("[data-typer]");
      if (typer && !reduceMotion) {
        const full = typer.dataset.typer || "";
        typer.textContent = "";
        let i = 0;
        // 延迟一点启动，等 Hero 的 reveal 动画播一帧
        setTimeout(() => {
          // CSS 在 .js 下把颜色设为透明防闪烁，此处逐字填入前恢复朱砂可见
          typer.style.color = "var(--vermilion)";
          const tick = () => {
            if (i < full.length) {
              typer.textContent += full[i++];
              setTimeout(tick, 85);
            }
          };
          tick();
        }, 450);
      }

      // ---- 动效 2：流水线节点滚动激活 ----
      // 滚到流水线区域时，四个节点从上到下依次点亮（朱砂填充），
      // 像流水线一节一节启动。stagger 间隔由 CSS --idx 控制。
      const rail = document.querySelector<HTMLElement>(".hero__rail");
      if (rail && "IntersectionObserver" in window && !reduceMotion) {
        const railIO = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                rail.classList.add("is-active");
                obs.disconnect();
              }
            });
          },
          { threshold: 0.3 }
        );
        railIO.observe(rail);
      }

      // ---- 动效 3：数字滚动计数 ----
      // 卡片内 [data-count] 元素，滚入视口时从 0 滚到目标值。
      const counters = document.querySelectorAll<HTMLElement>("[data-count]");
      if (counters.length) {
        const animateCount = (el: HTMLElement) => {
          const target = parseInt(el.dataset.count || "0", 10);
          if (reduceMotion) {
            el.textContent = String(target);
            return;
          }
          const dur = 900;
          const start = performance.now();
          const step = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            // easeOutCubic
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = String(Math.round(target * eased));
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        };
        if ("IntersectionObserver" in window) {
          const countIO = new IntersectionObserver(
            (entries, obs) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  animateCount(e.target as HTMLElement);
                  obs.unobserve(e.target);
                }
              });
            },
            { threshold: 0.6 }
          );
          counters.forEach((el) => countIO.observe(el));
        } else {
          counters.forEach((el) => animateCount(el));
        }
      }

      // ---- 动效 4：特性卡片 3D 倾斜 ----
      // 仅精确指针设备：鼠标在卡片上移动时轻微倾斜，配合现有 hover 上浮。
      if (!reduceMotion && window.matchMedia("(pointer: fine)").matches) {
        document
          .querySelectorAll<HTMLElement>(".card")
          .forEach((card) => {
            const onMove = (e: MouseEvent) => {
              const r = card.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width - 0.5;
              const py = (e.clientY - r.top) / r.height - 0.5;
              card.style.setProperty("--rx", `${(-py * 6).toFixed(2)}deg`);
              card.style.setProperty("--ry", `${(px * 6).toFixed(2)}deg`);
            };
            const reset = () => {
              card.style.setProperty("--rx", "0deg");
              card.style.setProperty("--ry", "0deg");
            };
            card.addEventListener("mousemove", onMove);
            card.addEventListener("mouseleave", reset);
          });
      }
    </script>

    <style>
      /* ---------- 全局基底 & token：见 src/styles/base.css ---------- */

      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 32px; }

      /* ---------- 顶部栏 ---------- */
      .topbar {
        position: sticky; top: 0; z-index: 50;
        background: color-mix(in srgb, var(--paper) 88%, transparent);
        backdrop-filter: saturate(140%) blur(10px);
        -webkit-backdrop-filter: saturate(140%) blur(10px);
        border-bottom: 1px solid var(--rule);
        transition: transform .35s cubic-bezier(.4,0,.2,1);
      }
      /* 向下滚动时隐藏，向上滚动或回到顶部时显示 */
      .topbar[data-hidden="true"] { transform: translateY(-100%); }
      .topbar[data-scrolled="true"] {
        border-bottom-color: color-mix(in srgb, var(--rule) 70%, transparent);
      }
      .topbar__inner {
        display: flex; align-items: center; justify-content: space-between;
        height: 68px;
        transition: height .3s ease;
      }
      .topbar[data-scrolled="true"] .topbar__inner { height: 58px; }
      .brand { display: inline-flex; align-items: center; gap: 9px; text-decoration: none; color: var(--ink); }
      .brand__mark { width: 26px; height: 26px; }
      .brand__name { font-family: var(--font-serif); font-weight: var(--fw-semibold); font-size: var(--fs-brand); letter-spacing: var(--tracking-cn); }
      .topbar__nav { display: flex; align-items: center; gap: 28px; }
      .topbar__nav a {
        text-decoration: none; color: var(--ink-2);
        font-family: var(--font-sans); font-size: var(--fs-body);
        transition: color .2s;
      }
      .topbar__nav a:hover { color: var(--ink); }
      .topbar__cta { color: var(--ink) !important; font-weight: var(--fw-semibold); }
      /* 当前页：朱砂短下划线标识（不抢 CTA 视觉） */
      .topbar__nav a.is-active {
        position: relative; color: var(--ink); font-weight: var(--fw-semibold);
      }
      .topbar__nav a.is-active::after {
        content: ""; position: absolute; left: 0; right: 0; bottom: -6px;
        height: 2px; background: var(--vermilion);
      }
      .topbar__cta.is-active::after { display: none; }

      /* ---------- HERO ---------- */
      .hero { padding: 88px 0 104px; border-bottom: 1px solid var(--rule); }
      .hero__grid {
        display: grid;
        grid-template-columns: 1.35fr 1fr;
        gap: 64px;
        align-items: start;
      }
      .kicker {
        display: inline-flex; align-items: center; gap: 9px;
        font-family: var(--font-sans); font-size: var(--fs-kicker);
        color: var(--ink-3); letter-spacing: var(--tracking-cn-body);
        margin-bottom: 26px;
      }
      .kicker__dot { width: 6px; height: 6px; background: var(--vermilion); border-radius: 50%; }
      .hero__title {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-display);
        line-height: var(--lh-tight); letter-spacing: var(--tracking-cn-tight); color: var(--ink);
      }
      .hero__title em { font-style: italic; color: var(--vermilion); }
      /* 打字机：.js 环境下渲染瞬间先用透明色隐藏目标字（HTML 里写了完整文本），
         JS 接管后逐字填入并恢复颜色，避免"满字闪一下→清空→重打"的闪烁。
         非 JS 环境没有 .js 类，文本正常显示。 */
      :global(.js) [data-typer] { color: transparent; }
      /* 朱砂书写光标：闪烁而非渐入，像停在句末的笔尖 */
      .caret {
        display: inline-block; width: 0.05em; height: 0.9em;
        background: var(--vermilion); margin-left: 0.04em;
        vertical-align: -0.08em;
        animation: blink 1.05s steps(2, end) infinite;
      }
      @keyframes blink { 50% { opacity: 0; } }
      .hero__sub {
        margin-top: 28px; max-width: 30em;
        font-size: var(--fs-body-lg); color: var(--ink-2); line-height: var(--lh-body);
      }
      .hero__cta { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; margin-top: 40px; }
      .hero__meta { font-family: var(--font-mono); font-size: var(--fs-kicker); color: var(--ink-3); font-variant-numeric: tabular-nums; }

      /* 按钮：墨水填充 hover + 磁吸位移（由 JS 写入 --mx/--my） */
      .btn {
        position: relative; overflow: hidden; isolation: isolate;
        display: inline-flex; align-items: center; gap: 10px;
        padding: 14px 26px;
        font-family: var(--font-sans); font-size: var(--fs-body);
        font-weight: var(--fw-semibold); text-decoration: none;
        color: var(--ink); background: transparent;
        border: 1px solid var(--ink);
        transform: translate(var(--mx, 0), var(--my, 0));
        transition:
          transform .35s cubic-bezier(.18, .9, .32, 1.2),
          color .25s ease;
      }
      .btn::before {
        content: ""; position: absolute; inset: 0; z-index: -1;
        background: var(--ink); transform: translateY(101%);
        transition: transform .3s cubic-bezier(.4,0,.2,1);
      }
      .btn:hover { color: var(--paper); }
      .btn:hover::before { transform: translateY(0); }
      .btn:hover .btn__arrow { transform: translateX(3px); }
      .btn__arrow { transition: transform .25s ease; }
      .btn--solid { color: var(--paper); }
      .btn--solid::before { transform: translateY(0); }
      .btn--solid:hover { color: var(--paper); }

      /* HERO 右栏：流水线 spine */
      .hero__rail {
        padding: 4px 0 4px 28px;
        border-left: 1px solid var(--rule);
      }
      .rail__label {
        font-family: var(--font-sans); font-size: var(--fs-meta);
        color: var(--ink-3); letter-spacing: var(--tracking-label);
        text-transform: uppercase; margin-bottom: 22px;
      }
      .pipeline { list-style: none; position: relative; }
      .pipeline__item {
        position: relative; display: grid;
        grid-template-columns: auto 1fr; column-gap: 14px;
        padding: 14px 0 14px 22px;
      }
      /* 竖线 + 节点 */
      .pipeline::before {
        content: ""; position: absolute; left: 4px; top: 8px; bottom: 8px;
        width: 1px; background: var(--rule);
      }
      .pipeline__node {
        position: absolute; left: 0; top: 22px;
        width: 9px; height: 9px; border-radius: 50%;
        background: var(--paper); border: 1.5px solid var(--ink-3);
      }
      /* 滚动激活接管节点点亮，首个节点不再写死朱砂 —— 未激活时全灰，进入视口后依次点亮 */
      /* 悬停某阶段：节点点亮成朱砂，像笔尖选中这一步 */
      .pipeline__item { transition: transform .2s ease; }
      .pipeline__item:hover { transform: translateX(3px); }
      .pipeline__item:hover .pipeline__node {
        border-color: var(--vermilion); background: var(--vermilion);
        transform: scale(1.15);
      }
      .pipeline__item:hover .pipeline__name { color: var(--vermilion); }
      .pipeline__node { transition: background .2s ease, border-color .2s ease, transform .2s ease; }
      .pipeline__name { transition: color .2s ease; }
      /* 滚动激活：.hero__rail 进入视口后加 .is-active，四节点依次点亮（朱砂），
         stagger 间隔由 --idx（模板里写入）× 250ms 控制，像流水线一节节启动。 */
      .pipeline.is-active .pipeline__node,
      .hero__rail.is-active .pipeline__item .pipeline__node {
        border-color: var(--vermilion); background: var(--vermilion);
        animation: node-pop .4s cubic-bezier(.2,.8,.3,1.4) calc(var(--idx, 0) * 200ms) both;
      }
      @keyframes node-pop {
        0%   { transform: scale(0); }
        60%  { transform: scale(1.3); }
        100% { transform: scale(1); }
      }
      .hero__rail.is-active .pipeline__item .pipeline__name {
        animation: name-in .5s ease calc(var(--idx, 0) * 200ms + 100ms) both;
      }
      @keyframes name-in {
        from { opacity: 0; transform: translateX(-6px); }
        to   { opacity: 1; transform: none; }
      }
      .pipeline__num {
        font-family: var(--font-mono); font-size: var(--fs-meta);
        color: var(--ink-3); font-variant-numeric: tabular-nums;
        align-self: start; padding-top: 2px; letter-spacing: var(--tracking-cn-body);
      }
      .pipeline__body { display: flex; flex-direction: column; }
      .pipeline__name { font-family: var(--font-serif); font-weight: var(--fw-semibold); font-size: var(--fs-body-lg); line-height: var(--lh-tight); letter-spacing: var(--tracking-cn); color: var(--ink); }
      .pipeline__desc { font-family: var(--font-sans); font-size: var(--fs-small); line-height: var(--lh-body); color: var(--ink-3); margin-top: 2px; }

      /* ---------- FEATURES bento ---------- */
      .features { padding: 104px 0 96px; }
      .section-head {
        display: grid; grid-template-columns: auto 1fr; column-gap: 24px;
        align-items: start; margin-bottom: 56px; max-width: 720px;
      }
      .section-num {
        font-family: var(--font-serif); font-size: var(--fs-body);
        font-weight: var(--fw-semibold);
        color: var(--vermilion); padding-top: 10px;
      }
      .section-title {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-h2); line-height: var(--lh-tight);
        letter-spacing: var(--tracking-cn); color: var(--ink);
      }
      .section-lead { margin-top: 16px; font-size: var(--fs-body); line-height: var(--lh-body); letter-spacing: var(--tracking-cn-body); color: var(--ink-2); max-width: 34em; }

      .bento {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        grid-template-rows: auto auto;
        gap: 1px;
        background: var(--rule);
        border: 1px solid var(--rule);
      }
      .card {
        position: relative;
        background: var(--paper);
        padding: 40px 38px;
        /* 3D 倾斜 + 上浮合一：--rx/--ry 由 JS mousemove 写入（指针设备），
           --lift 控制 hover 上浮，默认 0 */
        transform: perspective(800px) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg)) translateY(var(--lift, 0px));
        transition: background .25s ease, transform .3s cubic-bezier(.2,.7,.3,1);
        transform-style: preserve-3d;
      }
      /* hover：轻微上浮 + 朱砂左边线（笔尖批注的暗示） + 倾斜由 JS 接管 */
      .card:hover { background: var(--paper-2); --lift: -3px; }
      .card::after {
        content: ""; position: absolute; left: 0; top: 0; bottom: 0;
        width: 2px; background: var(--vermilion);
        transform: scaleY(0); transform-origin: top;
        transition: transform .3s cubic-bezier(.4,0,.2,1);
      }
      .card:hover::after { transform: scaleY(1); }
      .card--lead { grid-row: span 2; padding: 48px 46px; }
      .card__icon {
        display: inline-flex; width: 38px; height: 38px; margin-bottom: 22px;
        color: var(--ink);
      }
      .card__icon :global(svg) { width: 100%; height: 100%; }
      /* stroke-draw：每条 path 以 0→1 描出，配合 pathLength="1" 统一坐标 */
      .card__icon :global(path) {
        stroke-dasharray: 1; stroke-dashoffset: 1;
        transition: stroke-dashoffset .7s cubic-bezier(.5,0,.2,1) .15s;
      }
      .card.is-revealed .card__icon :global(path),
      .card:hover .card__icon :global(path) { stroke-dashoffset: 0; }
      /* 聚焦时图标转朱砂，增强关联感 */
      .card:hover .card__icon { color: var(--vermilion); }
      .card__icon { transition: color .25s ease; }
      .card--lead .card__icon { width: 46px; height: 46px; }
      .card__title {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-h5); line-height: var(--lh-tight);
        letter-spacing: var(--tracking-cn); color: var(--ink);
      }
      .card--lead .card__title { font-size: var(--fs-h4); }
      .card__desc { margin-top: 8px; font-size: var(--fs-body); line-height: var(--lh-body); letter-spacing: var(--tracking-cn-body); color: var(--ink-3); }
      .card__body { margin-top: 20px; }
      /* markdown h1 与 frontmatter title 重复，隐藏前者 */
      .card__body :global(h1:first-child) { display: none; }
      .card__body :global(p) { font-size: var(--fs-body); line-height: var(--lh-body); letter-spacing: var(--tracking-cn-body); color: var(--ink-2); }
      .card__body :global(p) + :global(ul) { margin-top: 12px; }
      .card__body :global(ul) { list-style: none; padding: 0; }
      .card__body :global(li) {
        position: relative; padding-left: 18px;
        font-size: var(--fs-body); line-height: var(--lh-body);
        letter-spacing: var(--tracking-cn-body);
        color: var(--ink-2); margin-top: 9px;
      }
      .card__body :global(li)::before {
        content: ""; position: absolute; left: 0; top: 0.7em;
        width: 8px; height: 1px; background: var(--vermilion);
      }

      /* ---------- CLOSING ---------- */
      .closing { border-top: 1px solid var(--rule); padding: 88px 0; }
      .closing__inner {
        display: flex; align-items: center; justify-content: space-between;
        gap: 32px; flex-wrap: wrap;
      }
      .closing__line {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-h4); line-height: var(--lh-tight);
        letter-spacing: var(--tracking-cn); color: var(--ink);
      }

      /* ---------- FOOTER ---------- */
      .foot { border-top: 1px solid var(--rule); }
      .foot__inner {
        display: flex; align-items: center; justify-content: space-between;
        height: 76px; gap: 24px;
      }
      .foot__copy { font-family: var(--font-sans); font-size: var(--fs-small); color: var(--ink-3); }
      .foot__seal {
        font-family: var(--font-serif); font-weight: var(--fw-semibold);
        font-size: var(--fs-meta);
        color: var(--paper); background: var(--vermilion);
        width: 26px; height: 26px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 3px; letter-spacing: 0;
      }
      .foot__nav { display: flex; gap: 24px; }
      .foot__nav a { text-decoration: none; font-family: var(--font-sans); font-size: var(--fs-small); color: var(--ink-2); transition: color .2s; }
      .foot__nav a:hover { color: var(--ink); }

      /* ---------- 滚动渐显 ---------- */
      /* 仅在 .js 下生效；无 JS 的环境直接显示，保证内容可见。 */
      :global(.js) [data-reveal] {
        opacity: 0;
        transform: translateY(14px);
        transition:
          opacity .65s cubic-bezier(.2,.7,.3,1),
          transform .65s cubic-bezier(.2,.7,.3,1);
        transition-delay: calc(var(--reveal-i, 0) * 90ms);
        will-change: opacity, transform;
      }
      :global(.js) [data-reveal].is-revealed { opacity: 1; transform: none; }

      /* ---------- 响应式 ---------- */
      @media (max-width: 900px) {
        .wrap { padding: 0 22px; }
        .hero { padding: 56px 0 64px; }
        .hero__grid { grid-template-columns: 1fr; gap: 48px; }
        .hero__rail { border-left: none; border-top: 1px solid var(--rule); padding: 32px 0 0; }
        .features { padding: 72px 0; }
        .bento { grid-template-columns: 1fr; }
        .card--lead { grid-row: auto; padding: 36px 30px; }
        .card { padding: 32px 30px; }
        .closing { padding: 56px 0; }
        .closing__inner { justify-content: flex-start; }
        .foot__inner { height: 64px; }
      }
      @media (max-width: 480px) {
        .topbar__nav { gap: 16px; }
        .hero__cta { gap: 14px; }
        .section-head { grid-template-columns: 1fr; }
      }

      @media (prefers-reduced-motion: reduce) {
        .btn::before, .btn__arrow, .btn, .card, .card::after,
        .card__icon, .card__icon :global(path),
        .pipeline__item, .pipeline__node, .pipeline__name,
        .topbar, .topbar__inner { transition: none !important; }
        .caret { animation: none; }
        :global(.js) [data-reveal] { opacity: 1 !important; transform: none !important; }
        :global(html) { scroll-behavior: auto; }
        /* reduced-motion：打字机直接显示全文，卡片不倾斜 */
        :global(.js) [data-typer] { color: var(--vermilion) !important; }
        .card { transform: none !important; }
        /* reduced-motion：流水线节点直接点亮，不靠滚动触发 */
        .pipeline__node { border-color: var(--vermilion) !important; background: var(--vermilion) !important; }
      }
    </style>
  </body>
</html>
