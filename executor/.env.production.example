# ─────────────────────────────────────────────────────────────
# executor 生产环境配置模板
# 用法：cp executor/.env.production.example executor/.env && 填真实值
# 此文件可入 git（无敏感值）；.env 不入 git
# ─────────────────────────────────────────────────────────────

# ── 写作 Agent 模型配置 ──
WRITER_MODEL=                  # 例：deepseek-chat / gpt-4o
WRITER_TEMPERATURE=0.7
WRITER_TOP_P=0.95
WRITER_AGENT_MODE=             # 见 app 代码支持的枚举值

# ── 前端源（CORS 白名单，写作前端生产域名）──
WRITER_FRONTEND_ORIGIN=https://siyen.site

# ── OpenAI 兼容接口 ──
OPENAI_API_KEY=                # 你的 LLM 供应商 key（敏感）
OPENAI_BASE_URL=               # 例：https://api.deepseek.com/v1

# ── 多用户加密主密钥（敏感，32 字节 hex/base64）──
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ 一旦设定不可更改——改了旧加密数据（用户存的 API key）无法解密
MASTER_KEY=

# ── 元数据库路径（容器内挂卷 executor_data → /app/executor）──
DB_PATH=app.platform.core.db

# ── 工作区根目录 ──
WORKSPACE_ROOT=workspace

# ── 引导管理员（首启动若无管理员则创建）──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                # 改为强密码（敏感）

# Session 有效期（天）
SESSION_TTL_DAYS=30

# 默认每用户作品配额
DEFAULT_WORKSPACE_QUOTA=5

# ── harness 包路径（容器内绝对路径，由 compose 注入，此处置空以免覆盖）──
# HARNESS_PACKAGE_PATH / HARNESS_BARE_REPO / HARNESS_CLONE_DIR
# 由 docker-compose.yml environment 注入（指向共享卷），无需在此设置。

# 注意：EVOLUTION_NOTIFY_URL / EVOLUTION_URL 由 docker-compose.yml 注入，
# 指向 http://evolution:7789（docker 服务名），无需在此设置。

# ── 记忆系统（NWM 重构，2026-07-17：去 Graphiti/FalkorDB）──
# 存储：SQLite 单文件 + sqlite-vec 向量扩展（pysqlite3 在 app/__init__.py 注入）。
#       memory.db 落在 MEMORY_DIR 下，按 workspace_id 分文件。
# 以下配置全部留空时，记忆系统自动关闭，writing 回退全量注入（不影响其他功能）。

# 记忆抽取 LLM（独立于写作模型，抽取是结构化任务用快模型不走思考模式）。
# 留空时回退到 OPENAI_API_KEY/OPENAI_BASE_URL/WRITER_MODEL。
MEMORY_EXTRACT_API_KEY=
MEMORY_EXTRACT_BASE_URL=
MEMORY_EXTRACT_MODEL=            # 推荐 deepseek-chat（非思考）或 glm-4.6

# 记忆 embedding（智谱 embedding-3，NWM 向量检索专用；DeepSeek 不提供 embedding API）。
# 获取：https://open.bigmodel.cn/ → API Keys
# 维度固定 2048（代码常量 MEMORY_EMBED_DIMENSION，换模型需重建向量表）。
MEMORY_EMBED_API_KEY=            # 智谱 API key（敏感）
MEMORY_EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MEMORY_EMBED_MODEL=embedding-3
