# ── 版本控制 ──
.git/
.gitignore

# ── Python 缓存与虚拟环境（镜像内重建，绝不打包进来）──
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
.venv/
venv/
**/.pytest_cache/

# ── Node（镜像内 npm ci 重建）──
**/node_modules/
**/.next/

# ── 前端构建产物（由容器内构建产生，避免宿主污染）──
evolution/frontend/out/
frontend/.next/
frontend/out/

# ── 运行时数据库与数据（挂卷管理，绝不入镜像）──
**/*.db
**/*.db-shm
**/*.db-wal
**/*.db.bak*
monitoring.db

# ── 运行时工作目录 ──
executor/workspace/
executor/checkpoints/
executor/checkpoints.db*
executor/.prompt_cache/
executor/.manifest_cache/
executor/.harness_checkout/

# ── harness bare repo 与工作目录（挂卷共享，不入镜像）──
evolution/harness.git/
evolution/harnesses/

# ── 环境变量（敏感，绝不入镜像；运行时通过 env_file 注入）──
**/.env
**/.env.*
!**/.env.example
!**/.env.production.example

# ── 文档与参考资料 ──
*.pdf
_paper_extract.txt
docs/

# ── IDE / OS ──
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Claude / Agents 本地产物 ──
.claude/md/
.agents/

# ── 顶层无关文件 ──
qd
nul
start.log
evolution/start.log
