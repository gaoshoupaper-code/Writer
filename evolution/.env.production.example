# ─────────────────────────────────────────────────────────────
# evolution 生产环境配置模板
# 用法：cp evolution/.env.production.example evolution/.env && 填真实值
# 此文件可入 git（无敏感值）；.env 不入 git
# ─────────────────────────────────────────────────────────────

# 服务端口（容器内固定 7789，不要改）
PORT=7789

# 执行端 workspace 根目录（trace jsonl 所在）
# 容器内：executor 与 evolution 不共享 workspace 卷，trace 走 HTTP 拉取（Phase 3 起）
EXECUTOR_WORKSPACE=executor/workspace

# SQLite 数据库文件路径（容器内挂卷 evolution_data → /app/evolution）
EVOLUTION_DB=evolution.db

# ── 内网 API Key（与 internal_auth 中间件配合）──
# 强随机串。留空则不校验（不推荐生产留空，因 evolution 有 git reset 等破坏性接口）。
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
# 同机 executor 不调 evolution 的危险接口，此 key 主要防止同机其他进程误操作。
INTERNAL_API_KEY=

# ── LLM-judge 评估配置 ──
# 留空则禁用 LLM-judge（仅规则标红）。
# 例：deepseek-chat / openai:gpt-4o-mini
JUDGE_MODEL=
JUDGE_API_KEY=
JUDGE_BASE_URL=

# 注意：EXECUTOR_URL 由 docker-compose.yml 的 environment 注入（http://executor:7788），
# 无需在此重复配置。
