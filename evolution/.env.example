# evolution 服务配置（复制为 .env 后修改）
# 服务端口
PORT=7789
# 执行端 workspace 根目录（trace jsonl 所在），相对路径基于项目根 Writer/
EXECUTOR_WORKSPACE=executor/workspace
# SQLite 数据库文件路径
EVOLUTION_DB=evolution.db

# 执行端服务地址（内网）：trace 拉取 + SSO 回调 /api/auth/me 验证
# 桌面化后双重用途，生产环境由 docker-compose 注入 http://executor:7788
EXECUTOR_URL=http://localhost:7788

# ── 大模型 API 配置（桌面化改造，2026-07-07）──
# LLM key/base_url/model 不再从 env 读，改在桌面端配置页填写
# （填后加密存 llm_config 表）。这里只配加密主密钥和鉴权相关。

# AES-256-GCM 主密钥（加密 llm_config 表的 api_key）。
# ⚠️ 设定后不可更改（历史加密 key 依赖它）。
# 生成：python -c "import secrets; print(secrets.token_hex(32))"
EVOLUTION_MASTER_KEY=

# SSO 白名单：允许访问 evolution 的 executor user_id（逗号分隔）。
# 桌面端登录 executor 后，evolution 回调 executor 验证 session，
# 校验 user_id ∈ 此白名单才放行。留空 = 开发模式（全放行，等价旧 internal_api_key 空）。
# 获取你的 user_id：登录 executor 后调 GET /api/auth/me
ALLOWED_USER_IDS=

# SSO 回调结果进程内缓存 TTL（秒），默认 60
SSO_CACHE_TTL_SECONDS=60

# 内网通知 token（executor → evolution /api/ingestion/notify 的 X-Notify-Token 头）。
# 留空 = 开发模式（不校验）。生产环境由 docker-compose 注入。
# 生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
NOTIFY_TOKEN=
