# evolution 服务配置（复制为 .env 后修改）
# 服务端口
PORT=7789
# 执行端 workspace 根目录（trace jsonl 所在），相对路径基于项目根 Writer/
EXECUTOR_WORKSPACE=executor/workspace
# SQLite 数据库文件路径
EVOLUTION_DB=evolution.db
# 执行端完成通知的接收端点（本服务暴露，执行端 POST 到此）
# 实际值为 http://127.0.0.1:${PORT}/ingestion/notify，执行端 NOTIFY_URL 配成它

# ── LLM-judge 评估配置（第二期）──
# 评估用模型，建议便宜小模型。留空则禁用 LLM-judge（仅规则标红）。
# 例：deepseek-chat / openai:gpt-4o-mini
JUDGE_MODEL=
JUDGE_API_KEY=
JUDGE_BASE_URL=
