# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 环境变量
executor/.env
executor/.env*

# 运行时数据
executor/workspace/
executor/checkpoints.db*
executor/checkpoints/
executor/app.db
executor/app.db-*
executor/app.db.bak.*
executor/app.platform.core.db*
executor/skills/
backup/
pre-multiuser-backup-*
forensics-*/

# 论文/参考资料（不入仓库）
*.pdf
_paper_extract.txt

# Node
node_modules/
.next/
out/
*.tsbuildinfo

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Claude Code 本地产物
.claude/md/

# 本地临时/调试文件（不提交，保留本地）
executor/diag.log
executor/spike_*.py

# 第三方/部署产物（独立部署，不入主仓库）
langfuse/

# evolution 服务：只入源码，不入运行产物
evolution/.env
evolution/**/*.db
evolution/**/*.db.bak
evolution/start.log
evolution/.pytest_cache/

# 监测前端构建产物（由容器内 npm run build 产生，或本地构建）
evolution/frontend/out/
evolution/frontend/.next/

# evolution 运行时产物（traces/evolve_workspace 等，由服务运行时生成）
# evalset/ 已跟踪的测试数据集不受影响（git 对已跟踪文件优先于 ignore）
evolution/data/traces/
evolution/data/evolve_workspace/

# evolution adapt 运行时产物（bare repo + checkout 缓存，动态生成）
evolution/harness.git/
.harness_checkout/

# 误产物（Windows 保留设备名，无法常规删除，忽略即可）
nul

.understand-anything/

# Claude Code 本地权限配置（含个人路径，不入库）
.claude/settings.local.json
