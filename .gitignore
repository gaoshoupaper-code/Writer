# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 运行时数据库（任何位置的 *.db 都不入库——曾误提交 monitoring.db 导致历史泄漏）
*.db
*.db-*
*.db.bak.*
*.db-shm
*.db-wal

# git 历史清除脚本生成的备份（含被清的敏感数据，仅本地保留）
backup-*.bundle

# 环境变量（.env* 通配会误伤 .env.production.example，需显式放行模板）
executor/.env
executor/.env.local
executor/.env.*.local
executor/.env*备份
executor/.env*联调*
# 模板文件可入 git（无敏感值）
!executor/.env.production.example
!executor/.env.example

# 运行时数据
executor/workspace/
executor/checkpoints.db*
executor/checkpoints/
executor/app.db
executor/app.db-*
executor/app.db.bak.*
executor/app.platform.core.db*
executor/skills/
backup/
pre-multiuser-backup-*
forensics-*/

# 论文/参考资料（不入仓库）
*.pdf
_paper_extract.txt

# Node
node_modules/
.next/
out/
*.tsbuildinfo

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Claude Code 本地产物
.claude/md/

# ZCode 本地产物
.zcode/

# 本地临时/调试文件（不提交，保留本地）
executor/diag.log
executor/spike_*.py

# 第三方/部署产物（独立部署，不入主仓库）
langfuse/

# evolution 服务：只入源码，不入运行产物
evolution/.env
evolution/**/*.db
evolution/**/*.db.bak
evolution/start.log
evolution/.pytest_cache/

# 监测前端构建产物（由容器内 npm run build 产生，或本地构建）
evolution/frontend/out/
evolution/frontend/.next/

# evolution 运行时产物（traces/evolve_workspace 等，由服务运行时生成）
# evalset/ 已跟踪的测试数据集不受影响（git 对已跟踪文件优先于 ignore）
evolution/data/traces/
evolution/data/evolve_workspace/
evolution/data/checkpoints/

# evolution adapt 运行时产物（bare repo + checkout 缓存，动态生成）
evolution/harness.git/
.harness_checkout/

# harness 独立 git 仓库（去 DB 重构）：源码随主仓库分发（Docker COPY 种子需要），
# 但排除其内部 .git/ 目录（避免双仓库 git 嵌套冲突）。
evolution/harnesses/repo/.git/
evolution/harnesses/repo/**/.git/

# 误产物（Windows 保留设备名，无法常规删除，忽略即可）
nul

.understand-anything/

# Claude Code 本地权限配置（含个人路径，不入库）
.claude/settings.local.json

# 桌面端改造（S7/S8）：releases 只跟踪 .gitkeep，安装包/签名/latest.json 不上库
releases/*
!releases/.gitkeep

# 桌面端 Tauri 运行时生成的 schema（构建产物）
desktop/src-tauri/gen/
